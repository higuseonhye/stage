# Supabase (required for app + RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI — full cascade: Anthropic → OpenAI → Groq → Google Gemini (each optional; next on failure)
ANTHROPIC_API_KEY=

# Models (Anthropic IDs; override if your account uses dated snapshots)
DISCUSSION_MODEL=claude-haiku-4-5
PERFORMANCE_MODEL=claude-sonnet-4-6

# Cap total runs per user per UTC day (default 20). Separate from per-question limit (3) in code.
MAX_RUNS_PER_DAY=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional per-tier OpenAI model IDs (default: OPENAI_MODEL or gpt-4o-mini)
# OPENAI_DISCUSSION_MODEL=
# OPENAI_PERFORMANCE_MODEL=

# Groq — optional fallback
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — optional last resort
# GOOGLE_GENERATIVE_AI_API_KEY=
# or GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash

# Observability (optional — leave unset in dev)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# API rate limits (optional — recommended for production)
# Create a Redis database at https://upstash.com — limits apply to /api/discuss and /api/context/*
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
