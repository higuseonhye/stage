# Supabase (required for app + RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI — Anthropic recommended; OpenAI used only as stream fallback when set
ANTHROPIC_API_KEY=

# Models (Anthropic IDs; override if your account uses dated snapshots)
DISCUSSION_MODEL=claude-haiku-4-5
PERFORMANCE_MODEL=claude-sonnet-4-6

# Cap total runs per user per UTC day (default 20). Separate from per-question limit (3) in code.
MAX_RUNS_PER_DAY=20

# Fallback when Anthropic fails mid-stream (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
